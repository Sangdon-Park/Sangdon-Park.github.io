  "daily_submission_limit": 3,
  "submission_limit_timezone": "Asia/Seoul",
  "submission_limit_scope": "team_per_day",
  "public_files": {
    "train": "hackerton/data/train.csv",
    "test": "hackerton/data/test.csv",
    "sample_submission": "hackerton/data/sample_submission.csv"
  },
  "private_answer_file": "hackerton_admin/answers/private_solution.csv"
}
